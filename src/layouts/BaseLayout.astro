---
const { title = "Tuneprism" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Curated music beyond the algorithm. No trends. No feeds. Just tracks worth keeping." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://tuneprism.com" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/tuneprismicon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content="Tuneprism" />
    <meta property="og:description" content="Curated music beyond the algorithm." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tuneprism.com" />
    <meta property="og:image" content="https://tuneprism.com/og.jpg" />

<!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Tuneprism" />
    <meta name="twitter:description" content="Curated music beyond the algorithm." />
    <meta name="twitter:image" content="https://tuneprism.com/og.jpg" />
    <title>{title}</title>
  </head>

  <body>
    <header>
      <a href="/" class="logo">tuneprism</a>
      <nav>
        <a href="/drops">drops</a>
        <a href="/about">about</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    background: #050505;
    color: #f5f5f5;
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  header {
    max-width: 760px;
    margin: 0 auto;
    padding: 32px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    color: #fff;
    text-decoration: none;
    font-size: 22px;
    letter-spacing: -0.04em;
    font-weight: 600;
  }

  nav {
    display: flex;
    gap: 18px;
  }

  nav a,
  main a {
    color: #aaa;
    text-decoration: none;
  }

  nav a:hover,
  main a:hover {
    color: #fff;
  }

  main {
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .eyebrow {
    color: #777;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 12px;
  }

  h2 {
    font-size: 48px;
    letter-spacing: -0.05em;
    margin: 10px 0;
  }

  .theme {
    color: #aaa;
    font-size: 20px;
    margin-bottom: 48px;
  }

  .songs {
    display: grid;
    gap: 18px;
    margin-bottom: 48px;
    font-size: 20px;
  }

.songs h3 {
  margin: 36px 0 14px;
  font-size: 18px;
  font-weight: 500;
  color: #f5f5f5;
}

.songs iframe {
  margin-bottom: 28px;
  border: 1px solid rgba(255,255,255,0.05);
}

.songs p {
  color: #aaa;
  line-height: 1.7;
}

.date {
  color: #777;
  font-size: 14px;
  margin-bottom: 24px;
}

.songs em {
  display: block;
  color: rgba(255,255,255,0.5);
  font-size: 14px;
  font-style: normal;
  margin: -6px 0 8px;
}

  @media (max-width: 600px) {
    h2 {
      font-size: 38px;
      letter-spacing: -0.03em;
    }

    header {
      align-items: flex-start;
      gap: 16px;
      flex-direction: column;
    }
  }

.intro {
  max-width: 520px;
  margin-bottom: 48px;
  color: rgba(255,255,255,0.7);
  font-size: 18px;
  line-height: 1.6;
}
</style>